// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Prisma v7 — generator provider is "prisma-client" (NOT "prisma-client-js")
// Client is generated to app/generated/prisma, import from '@/app/generated/prisma'

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

// Connection URLs are supplied entirely by prisma.config.ts (Prisma v7 convention)
// url and directUrl are NOT set here — Prisma v7 removed support for them in schema files
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────

// D-04: PostgreSQL native enum for reservation lifecycle states
enum ReservationStatus {
  pending    // item is held; payment not yet confirmed
  confirmed  // payment succeeded; inventory permanently decremented
  released   // reservation expired or payment failed; hold removed
}

// ─────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  sku         String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory    Inventory[]
  reservations Reservation[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())

  inventory    Inventory[]
  reservations Reservation[]
}

// D-01: Denormalized reservedQty counter. availableQty = qty - reservedQty.
// D-02: Fields: id, productId, warehouseId, qty, reservedQty, updatedAt.
// D-05: @@unique([productId, warehouseId]) — one row per product-warehouse pair.
// NOTE: CHECK constraints (qty >= 0, reservedQty >= 0) added via custom migration SQL in Plan B.
//       Prisma SDL cannot express CHECK constraints natively.
model Inventory {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  qty         Int
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  // D-05: Exactly one inventory row per product-warehouse pair
  @@unique([productId, warehouseId])
}

// D-04: Uses ReservationStatus enum (pending/confirmed/released).
// D-06: @@index([status, expiresAt]) optimizes the cron sweeper query:
//       WHERE status = 'pending' AND expiresAt < now()
model Reservation {
  id             String            @id @default(cuid())
  productId      String
  warehouseId    String
  qty            Int
  status         ReservationStatus @default(pending)
  idempotencyKey String?           @unique  // Redis idempotency key (Phase 2)
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  // D-06: Optimized for cron sweeper: WHERE status='pending' AND expiresAt < now()
  @@index([status, expiresAt])
}
